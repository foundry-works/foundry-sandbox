# foundry.yaml — Git Safety Layer Configuration
# Place this file in your workspace root or set FOUNDRY_CONFIG_PATH.

version: "1.0"

git_safety:
  server:
    host: "127.0.0.1"
    port: 8083
    secrets_path: "~/.foundry/secrets/sandbox-hmac"
    data_dir: "~/.foundry/data/git-safety"

  protected_branches:
    enabled: true
    patterns:
      - "refs/heads/main"
      - "refs/heads/master"
      - "refs/heads/release/*"
      - "refs/heads/production"

  file_restrictions:
    blocked_patterns:
      - ".github/workflows/"
      - ".github/actions/"
      - "Makefile"
      - "Justfile"
      - "Taskfile.yml"
      - ".pre-commit-config.yaml"
      - "CODEOWNERS"
      - ".github/FUNDING.yml"
      - ".env*"
    warned_patterns:
      - "package.json"
      - "pyproject.toml"
      - "requirements.txt"
      - "requirements-*.txt"
      - "Gemfile"
      - "go.mod"
      - "go.sum"
      - "Cargo.toml"
      - "Cargo.lock"
      - "docker-compose*.yml"
      - "Dockerfile"
    warn_action: "reject"  # "reject" (default, blocks push) or "log" (warn only)

  branch_isolation:
    enabled: true
    well_known_branches:
      - "main"
      - "master"
      - "develop"
      - "production"
    well_known_prefixes:
      - "release/"
      - "hotfix/"

  rate_limits:
    burst: 300
    sustained: 120
    global_ceiling: 1000

  # Deep policy sidecar — YAML-driven request-shape policies.
  # Off by default. Enable to generalize the GitHub API filter to any service.
  # deep_policy:
  #   enabled: false
  #   policy_file: "bundled://github-default"  # or path to custom YAML
  #   circuit_breaker_threshold: 5
  #   circuit_breaker_recovery_seconds: 30
