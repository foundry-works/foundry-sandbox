# User-Defined Services
#
# **DEPRECATED** — Use foundry.yaml instead. This file is still read as a
# fallback, but a deprecation warning is logged. Migrate by adding a
# `user_services:` section to your repo's foundry.yaml:
#
#   version: "1"
#   user_services:
#     - name: OpenRouter
#       env_var: OPENROUTER_API_KEY
#       domain: openrouter.ai
#       header: Authorization
#       format: bearer
#
# See docs/configuration.md for the full foundry.yaml schema.
#
# Legacy format below.

version: "1"

services:
  # --- Bearer token example (Authorization: Bearer <key>) ---
  #
  # - name: OpenRouter
  #   env_var: OPENROUTER_API_KEY
  #   domain: openrouter.ai
  #   header: Authorization
  #   format: bearer
  #   paths: ["/api/**"]

  # --- Bearer token with multiple path prefixes ---
  #
  # - name: Groq
  #   env_var: GROQ_API_KEY
  #   domain: api.groq.com
  #   header: Authorization
  #   format: bearer
  #   paths: ["/openai/**", "/v1/**"]

  # --- Raw value example (X-Api-Key: <key>) ---
  #
  # - name: CustomService
  #   env_var: CUSTOM_API_KEY
  #   domain: api.custom.example
  #   header: X-Api-Key
  #   format: value

  # --- Restricted methods ---
  #
  # - name: ReadOnlyAPI
  #   env_var: READONLY_API_KEY
  #   domain: api.readonly.example
  #   header: Authorization
  #   format: bearer
  #   methods: [GET]
  #   paths: ["/v1/**"]

# Field reference:
#
#   name       (required)  Display name and slug source for the proxy route
#   env_var    (required)  Host environment variable holding the real API key
#                          Must match [A-Z_][A-Z0-9_]*
#   domain     (required)  Upstream domain to forward requests to
#   header     (required)  HTTP header name for credential injection
#   format     (required)  "bearer" -> "Bearer <key>", "value" -> raw key
#   methods    (optional)  Allowed HTTP methods (default: all standard methods)
#   paths      (optional)  Allowed URL path globs (default: all paths)
#   scheme     (optional)  Upstream scheme (default: "https")
#   port       (optional)  Upstream port (default: scheme default)
