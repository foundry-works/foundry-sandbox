# User-Defined Services
#
# Define custom API services for credential injection via the host-side
# reverse proxy. Copy this file to config/user-services.yaml and uncomment
# the services you need.
#
# Each service gets:
#   - A reverse-proxy route on the git-safety server (host-side)
#   - An environment variable injected into the sandbox pointing at the proxy
#   - Real credentials never enter the sandbox VM
#
# How it works:
#   The sandbox agent calls http://host.docker.internal:8083/proxy/<slug>/...
#   The proxy reads the real API key from the host environment, adds the
#   configured header, and forwards the request to the upstream service.
#   No MITM, no custom CA.
#
# Config file search order:
#   1. FOUNDRY_USER_SERVICES_PATH environment variable
#   2. ./config/user-services.yaml (relative to project root)
#
# Limitations:
#   - Header-based credential injection only
#   - SDKs must support custom base URLs (e.g., TAVILY_API_BASE)
#   - No OAuth token refresh flows
#   - No request body injection
#
# See docs/configuration.md for full documentation.

version: "1"

services:
  # --- Bearer token example (Authorization: Bearer <key>) ---
  #
  # - name: OpenRouter
  #   env_var: OPENROUTER_API_KEY
  #   domain: openrouter.ai
  #   header: Authorization
  #   format: bearer
  #   paths: ["/api/**"]

  # --- Bearer token with multiple path prefixes ---
  #
  # - name: Groq
  #   env_var: GROQ_API_KEY
  #   domain: api.groq.com
  #   header: Authorization
  #   format: bearer
  #   paths: ["/openai/**", "/v1/**"]

  # --- Raw value example (X-Api-Key: <key>) ---
  #
  # - name: CustomService
  #   env_var: CUSTOM_API_KEY
  #   domain: api.custom.example
  #   header: X-Api-Key
  #   format: value

  # --- Restricted methods ---
  #
  # - name: ReadOnlyAPI
  #   env_var: READONLY_API_KEY
  #   domain: api.readonly.example
  #   header: Authorization
  #   format: bearer
  #   methods: [GET]
  #   paths: ["/v1/**"]

# Field reference:
#
#   name       (required)  Display name and slug source for the proxy route
#   env_var    (required)  Host environment variable holding the real API key
#                          Must match [A-Z_][A-Z0-9_]*
#   domain     (required)  Upstream domain to forward requests to
#   header     (required)  HTTP header name for credential injection
#   format     (required)  "bearer" -> "Bearer <key>", "value" -> raw key
#   methods    (optional)  Allowed HTTP methods (default: all standard methods)
#   paths      (optional)  Allowed URL path globs (default: all paths)
#   scheme     (optional)  Upstream scheme (default: "https")
#   port       (optional)  Upstream port (default: scheme default)
